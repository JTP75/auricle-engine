# auricle-engine configuration
# Copy to .env and edit. Environment variables override these values.
# All settings have built-in defaults — only uncomment what you need to change.


# ── Audio devices ──────────────────────────────────────────────────────────────
# Run `arecord -l` to list capture devices, `aplay -l` to list playback devices.
# For Jabra Speak 510 USB: both mic and speaker are on the same ALSA device.

# AURICLE_MIC_DEVICE=plughw:0,0
# AURICLE_SPEAKER_DEVICE=plughw:0,0

# Audio backend — arecord/aplay (Linux/ALSA default) or sounddevice (cross-platform)
# AURICLE_AUDIO_INPUT=arecord
# AURICLE_AUDIO_OUTPUT=aplay

# sounddevice device specifier — integer index or name substring (blank = system default)
# Only relevant when AURICLE_AUDIO_INPUT or AURICLE_AUDIO_OUTPUT is set to sounddevice.
# AURICLE_SD_INPUT_DEVICE=
# AURICLE_SD_OUTPUT_DEVICE=


# ── STT ────────────────────────────────────────────────────────────────────────
# AURICLE_STT_BACKEND=vosk

# vosk backend (default)
# AURICLE_VOSK_MODEL_PATH=models/vosk-model

# whisper backend — requires torch, transformers, accelerate, webrtcvad-wheels in the engine venv
# AURICLE_STT_BACKEND=whisper
# AURICLE_WHISPER_MODEL_ID=distil-whisper/distil-large-v3


# ── TTS ────────────────────────────────────────────────────────────────────────
# AURICLE_TTS_BACKEND=edge-tts

# edge-tts backend (default, requires internet)
# Run `edge-tts --list-voices` to see available voices.
# AURICLE_TTS_VOICE=en-GB-LibbyNeural

# f5-tts backend — requires f5_tts, torch, torchaudio in the engine venv (GPU recommended)
# AURICLE_TTS_BACKEND=f5-tts
# AURICLE_F5_MODEL=F5TTS_v1_Base
# AURICLE_F5_STEPS=5
# AURICLE_F5_SPEED=1.0
# Voice cloning — both must be set together, or neither (falls back to bundled voice)
# AURICLE_F5_REF_WAV=/path/to/reference.wav
# AURICLE_F5_REF_TXT=/path/to/reference.txt

# kokoro-tts backend — requires kokoro, soundfile in the engine venv + espeak-ng on PATH
# AURICLE_TTS_BACKEND=kokoro-tts
# af_*/am_* = American English; bf_*/bm_* = British English
# AURICLE_KOKORO_VOICE=af_heart


# ── Wakeword (openWakeWord) ────────────────────────────────────────────────────
# AURICLE_OWW_WAKEWORD_MODEL_PATH=models/wakeword.onnx
# AURICLE_OWW_MELSPEC_MODEL_PATH=models/melspectrogram.onnx
# AURICLE_OWW_EMBEDDING_MODEL_PATH=models/embedding_model.onnx


# ── Behaviour ──────────────────────────────────────────────────────────────────
# Start with wakeword detection disabled (useful when testing TTS/STT in isolation)
# AURICLE_MUTE=false

# Seconds of open mic after TTS ends before requiring the wakeword again
# AURICLE_ACTIVE_LISTEN_DURATION=5

# Auto-sleep: gate the OWW model after this many seconds of acoustic silence in IDLE
# AURICLE_SLEEP_TIMEOUT=60

# How much the instantaneous spectral flux must exceed the sleep baseline to wake
# Lower = more sensitive (wakes on quieter sounds)
# AURICLE_SLEEP_WAKE_SENSITIVITY=3.0

# Normalised flux EMA cutoff for "quiet" classification
# AURICLE_SLEEP_FLUX_THRESHOLD=0.02


# ── WebSocket server ───────────────────────────────────────────────────────────
# AURICLE_ENGINE_PORT=57310

# Bind address — change to 0.0.0.0 to accept connections from remote clients
# (e.g. connector running on a different machine over Tailscale)
# AURICLE_ENGINE_HOST=localhost
